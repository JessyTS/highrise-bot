{
  "name": "highrise-complete-bot",
  "version": "5.0.0",
  "description": "Bot Highrise complet pour PlanetHoster N0C/Passenger : 65 commandes, état persistant, tips sécurisés et logs privés admins.",
  "main": "app.js",
  "type": "commonjs",
  "scripts": {
    "start": "node app.js",
    "start:bot": "node src/index.js",
    "dev": "node --watch app.js",
    "dev:bot": "node --watch src/index.js",
    "check": "node scripts/check-syntax.js",
    "test": "node --test"
  },
  "engines": {
    "node": ">=22"
  },
  "keywords": [
    "highrise",
    "bot",
    "moderation",
    "emotes",
    "nodejs",
    "planethoster",
    "passenger"
  ],
  "license": "MIT",
  "dependencies": {
    "dotenv": "17.4.2",
    "highrise.bot": "2.7.6"
  },
  "overrides": {
    "axios": "1.18.1"
  }
}
