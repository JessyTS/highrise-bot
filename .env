# Hébergement PlanetHoster N0C / Passenger
# Garde ces valeurs pour PlanetHoster. En local : HOSTING_MODE=local et WEB_PORT=3000.
HOSTING_MODE=planethoster
WEB_HOST="localhost"
WEB_PORT=8000
STATUS_PAGE_NAME=Highrise Complete Bot

# Identifiants obligatoires
HIGHRISE_TOKEN=f7983cc150248296c39bec503f6001f3cf7a51e2fbed1609aefb073d06f4aba8
HIGHRISE_ROOM_ID=68b737e5e30d06efa07eb8e7

# Commandes
BOT_PREFIX=!
BOT_ADMINS=625f1a134c3b246c88858eef
COMMAND_COOLDOWN_MS=2500
BULK_ACTION_DELAY_MS=400
BULK_MAX_USERS=200
DIRECT_EMOTES_ENABLED=true
DIRECT_EMOTE_COOLDOWN_MS=800
EMOTE_LOOP_LEAD_MS=250
EMOTE_LOOP_MIN_INTERVAL_MS=800
EMOTE_LOOP_RETRY_DELAY_MS=1200
EMOTE_LOOP_MAX_ERRORS=3

# Tips envoyés avec le gold du bot (désactivés par défaut)
TIPS_ENABLED=false
TIP_MAX_AMOUNT=100
TIP_DAILY_LIMIT=500
TIP_ADMIN_DAILY_LIMIT=500
TIP_RECIPIENT_DAILY_LIMIT=250
TIP_CONFIRM_SECONDS=60
TIP_SPLIT_ENABLED=true
TIP_BULK_ENABLED=false
TIP_BULK_MAX_RECIPIENTS=20
TIP_SEND_DELAY_MS=400

# Journal des actions : envoyé uniquement en whisper au propriétaire et aux admins du bot
ADMIN_LOGS_ENABLED=true
ADMIN_LOG_DENIED_ATTEMPTS=true
ADMIN_LOG_INCLUDE_ARGUMENTS=true
ADMIN_LOG_MAX_HISTORY=2000

# Relais des événements de la salle
EVENT_REPORTER_ENABLED=true
EVENT_PUBLIC_MESSAGES=false
EVENT_PRIVATE_MESSAGES=true
EVENT_EMOTE_COOLDOWN_SECONDS=15

# Accueil
WELCOME_ENABLED=true
WELCOME_MESSAGE=Bienvenue @{user} ! Tape {prefix}help pour voir les commandes.

# Modération automatique (désactivée par défaut pour éviter les faux positifs)
ANTI_SPAM_ENABLED=false
SPAM_MAX_MESSAGES=7
SPAM_WINDOW_SECONDS=8
SPAM_MUTE_SECONDS=60
WORD_FILTER_ENABLED=false
FILTER_MUTE_SECONDS=60
WARN_LIMIT=3
MAX_MOD_DURATION_DAYS=365

# Journalisation de la console
LOG_LEVEL=info
